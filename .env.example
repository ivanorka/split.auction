# Local development uses the same Neon database as split.auction.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/auction_split?sslmode=require

# Stripe Checkout: use sk_test_... while validating the sandbox integration.
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_sandbox_key
APP_URL=http://localhost:5173

# Transactional email delivery. Resend runs locally and in production with the same API.
RESEND_API_KEY=re_replace_with_resend_api_key
EMAIL_FROM="Auction Split <notifications@mail.split.auction>"
NOTIFICATION_EMAIL=ivanxiaomicroatia@gmail.com

# Optional SMTP fallback when Resend is intentionally unavailable.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
